# OS files
.DS_Store
**/.DS_Store

# Dependencies
node_modules/

# Build output
dist/

# IDE
.idea/
*.swp
*.swo

# Environment
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*

# Screenshots and media
*.png
*.jpg
*.jpeg
*.gif

# Local Claude Code settings (machine-specific permissions)
.claude/settings.local.json

# User projects — each user adds their own repos here
# See projects/example/ for the expected structure
projects/*/
!projects/example/
!projects/product-os/
!projects/projects.example.json

# User sprint data (root-level sprints for product-os itself)
/sprints/

# User project registry
projects/projects.json
